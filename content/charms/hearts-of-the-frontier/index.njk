---
layout: base.njk
title: "Hearts of the Frontier — Custom Designs LA"
description: "Western-inspired sterling silver charms celebrating heritage, resilience, and frontier spirit."
permalink: /charms/hearts-of-the-frontier/
---

<div class="collection-page">

<div class="collection-page-header-image-wrap">
  <img
    src="/static/img/hearts-of-the-frontier-charm-collection.png"
    alt="Hearts of the Frontier collection header"
    class="collection-page-header-image"
  >
</div>

<div class="collection-grid">
  {% for item in collections["hearts-of-the-frontier"] %}
    <a href="{{ item.url }}" class="collection-card">
      <img
        src="{{ item.data.gallery[0] }}"
        alt="{{ item.data.title }}"
        loading="lazy"
      >
      <div class="collection-card-text">
        <h3>{{ item.data.title }}</h3>
        <p class="price">${{ item.data.price }} USD</p>
      </div>
    </a>
  {% endfor %}
</div>

</div>
