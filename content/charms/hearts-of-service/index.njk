---
layout: base.njk
title: "Hearts of Service — Custom Designs LA"
description: "Sterling silver charms honoring medical professionals, service, and dedication."
permalink: /charms/hearts-of-service/
---

<header class="collection-intro">
  <div class="collection-intro-row">
    <span class="collection-accent" aria-hidden="true"></span>
    <h1 class="collection-intro-title">Hearts of Service</h1>
    <span class="collection-accent" aria-hidden="true"></span>
  </div>
  <p class="collection-intro-subtitle">COLLECTION</p>
</header>

<div class="collection-grid">
  {% for item in collections["hearts-of-service"] %}
    <a href="{{ item.url }}" class="collection-card">
      {% if item.data.images and item.data.images.length %}
        <img
          src="{{ item.data.images[0] }}"
          alt="{{ item.data.title }}"
          loading="lazy"
        >
      {% endif %}
      <div class="collection-card-text">
        <h3>{{ item.data.title }}</h3>
        <p class="price">${{ item.data.price }} USD</p>
      </div>
    </a>
  {% endfor %}
</div>
