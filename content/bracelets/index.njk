<div class="collections-page">

  <div class="collections-intro-heading">
    <div class="collection-header-art">
      <img
        class="collection-header-art-img"
        src="/static/img/explore-bracelet-collections.png"
        alt="Explore Bracelet Collections"
        loading="eager"
        decoding="async"
      >
    </div>
  </div>

<section class="collection-grid">

  <!-- Charm Bracelets -->
  <a href="/bracelets/charm/" class="collection-card">
    <div class="collection-image">
      <img
        src="/static/img/bracelets-charm.jpg"
        alt="Charm Bracelets Collection"
        loading="lazy"
      >
    </div>
    <div class="collection-title-image-wrap" aria-label="Charm Bracelets Collection">
      <img class="collection-title-image" src="/static/img/charm-bracelet-collection.png" alt="Charm Bracelets Collection title" loading="lazy" decoding="async" onerror="this.closest('.collection-title-image-wrap').classList.add('is-hidden')">
    </div>
  </a>

  <!-- Cuff Bracelets -->
  <a href="/bracelets/cuff/" class="collection-card">
    <div class="collection-image">
      <img
        src="/static/img/bracelets-cuff.jpg"
        alt="Cuff Bracelets Collection"
        loading="lazy"
      >
    </div>
    <div class="collection-title-image-wrap" aria-label="Cuff Bracelets Collection">
      <img class="collection-title-image" src="/static/img/cuff-bracelet-collection.png" alt="Cuff Bracelets Collection title" loading="lazy" decoding="async" onerror="this.closest('.collection-title-image-wrap').classList.add('is-hidden')">
    </div>
  </a>

</section>

</div>
