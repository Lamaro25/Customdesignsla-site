<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{{ title | default("Custom Design's LA") }}</title>

  <link rel="stylesheet" href="/static/css/styles.css">
  <link rel="stylesheet" href="/static/css/ltr.css">

  <!-- Collections Toggle Styles + Sticky Header -->
  <style>
    .site-brand,
    .header-brand,
    .header-logo-row {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-start !important;
      gap: 4px !important;
      width: 100% !important;
      margin-bottom: 0 !important;
      padding-bottom: 0 !important;
    }

    .cdla-header-wordmark,
    .cdla-header-img {
      display: block !important;
      width: clamp(230px, 52vw, 320px) !important;
      max-width: 320px !important;
      height: auto !important;
      object-fit: contain !important;
      flex-shrink: 1 !important;
      margin: 0 auto !important;
    }

    .site-logo,
    .header-logo,
    .logo {
      display: flex !important;
      justify-content: center !important;
      align-items: center !important;
      margin: 2px auto 0 auto !important;
      padding: 0 !important;
      flex-shrink: 0 !important;
      position: relative !important;
      z-index: 2 !important;
    }

    .site-logo img,
    .header-logo img,
    .logo img,
    .brand-logo {
      display: block !important;
      width: clamp(40px, 8vw, 52px) !important;
      max-width: 52px !important;
      height: auto !important;
      object-fit: contain !important;
      margin: 0 auto !important;
    }

    .collections-toggle,
    .collection-toggle,
    .nav-collections-button,
    .collections-link {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: flex-start !important;
      width: auto !important;
      height: auto !important;
      padding: 0 !important;
      margin-left: 14px !important;
      margin-top: -14px !important;
      margin-bottom: -6px !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      cursor: pointer !important;
    }

    .cdla-collections-button-img,
    .collections-link img,
    .collections-toggle img,
    .collection-toggle img,
    .nav-collections-button img {
      display: block !important;
      width: clamp(135px, 34vw, 165px) !important;
      max-width: 165px !important;
      height: auto !important;
      object-fit: contain;
    }


    .top-button-bar {
      display: none;
    }

    .top-button-bar.is-open {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: nowrap; /* Desktop: single row */
      padding: 0.45rem 0.7rem;
    }

    /* Button images: base size */
    .top-button-bar a img {
      height: 38px;
      width: auto;
      display: block;
    }

    /* Hide future buttons (keep in code) */
    .nav-hidden {
      display: none !important;
    }

    /* Mobile: 3 on top, 2 centered */
    @media (max-width: 768px) {
      .top-button-bar.is-open {
        flex-wrap: wrap;
        max-width: 360px;
        margin: 0 auto;
        justify-content: center;
      }

      .top-button-bar a img {
        height: 36px;
      }
    }

    /* Desktop: make nav buttons bigger */
    @media (min-width: 769px) {
      .top-button-bar.is-open {
        padding-top: 0.35rem;
        padding-bottom: 0.6rem;
        gap: 0.9rem;
      }

      .top-button-bar a img {
        height: 44px;
      }

    }


    .site-header,
    header {
      position: sticky;
      top: 0;
      z-index: 1500;
      background: radial-gradient(
        circle at center,
        rgba(68,70,72,0.96) 0%,
        rgba(34,35,37,0.96) 52%,
        rgba(13,14,15,0.98) 100%
      );
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.18),
        inset 0 -1px 0 rgba(0,0,0,0.55),
        0 8px 22px rgba(0,0,0,0.22);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border-bottom: 1px solid rgba(255,255,255,0.18);
      min-height: unset !important;
      height: auto !important;
      padding-top: 6px !important;
      padding-bottom: 0px !important;
    }

    main {
      padding-top: 1.5rem;
    }

    @media (max-width: 768px) {
      main {
        padding-top: 1.5rem;
      }
    }

    @media (max-width: 768px) {
      .site-header,
      header {
        min-height: 124px !important;
        height: auto !important;
        max-height: none !important;
        padding-top: 6px !important;
        padding-bottom: 4px !important;
        margin: 0 !important;
        overflow: visible !important;
        position: relative !important;
      }

      .site-header.collections-open,
      header.collections-open,
      .site-header:has(.top-button-bar.is-open),
      header:has(.top-button-bar.is-open) {
        padding-bottom: 56px !important;
      }

      .header-brand,
      .site-brand,
      .header-logo-row {
        position: relative !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 100% !important;
        height: 62px !important;
        margin: 4px auto 0 auto !important;
        padding: 0 !important;
        text-align: center !important;
      }

      .cdla-header-wordmark {
        display: block !important;
        width: clamp(200px, 49vw, 260px) !important;
        max-width: 260px !important;
        height: auto !important;
        object-fit: contain !important;
        margin: 4px auto 0 auto !important;
      }

      .site-logo,
      .header-logo,
      .logo,
      .brand-logo {
        position: absolute !important;
        right: 48px !important;
        top: 50% !important;
        transform: translateY(-45%) !important;
        margin: 0 !important;
        padding: 0 !important;
        z-index: 3 !important;
      }

      .site-logo img,
      .header-logo img,
      .logo img,
      .brand-logo {
        width: 42px !important;
        max-width: 42px !important;
        height: auto !important;
        object-fit: contain !important;
      }

      .collections-toggle,
      .collection-toggle,
      .nav-collections-button,
      .collections-link {
        position: absolute !important;
        left: 14px !important;
        top: 78px !important;
        bottom: auto !important;
        margin: 0 !important;
        padding: 0 !important;
        z-index: 40 !important;
      }

      .top-button-bar {
        position: absolute !important;
        left: 14px !important;
        top: 120px !important;
        bottom: auto !important;
        z-index: 50 !important;
        pointer-events: none !important;
      }

      .top-button-bar.is-open {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        align-items: center !important;
        justify-content: flex-start !important;
        gap: 8px !important;
        flex-wrap: nowrap !important;
        max-width: none !important;
        margin: 0 !important;
        padding: 0 !important;
        pointer-events: auto !important;
      }

      .top-button-bar .nav-btn {
        pointer-events: auto !important;
        position: relative !important;
        z-index: 51 !important;
        white-space: nowrap !important;
      }

      .top-button-bar .nav-btn img {
        height: 34px !important;
      }

      .collection-card:last-child {
        margin-bottom: 8px !important;
      }

      footer,
      .site-footer {
        margin-top: 6px !important;
        padding-top: 6px !important;
      }
    }
  </style>
</head>

<body>

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand header-logo-row">
      <img
        src="/static/img/cdla-header-wordmark.png"
        alt="Custom Design’s LA"
        class="cdla-header-wordmark"
      >
      <img
        src="/assets/uploads/logo.png"
        alt="Custom Design's LA Logo"
        class="brand-logo"
      />
    </a>
  </div>

  <a class="collections-toggle" href="#" aria-label="Collections">
    <img
      src="/static/img/collections-filigree-button.png"
      alt="Collections"
      class="cdla-collections-button-img"
    >
  </a>

  <div class="top-button-bar" id="collections-bar">

    <!-- ✅ LIVE BUTTONS (ONLY 5) -->
    <a class="nav-btn nav-rings" href="/rings/">
      <img src="/static/img/buttons/rings.png" alt="Rings">
    </a>

    <a class="nav-btn nav-charms" href="/charms/">
      <img src="/static/img/buttons/charms.png" alt="Charms">
    </a>

    <a class="nav-btn nav-bracelets" href="/bracelets/">
      <img src="/static/img/buttons/bracelets.png" alt="Bracelets">
    </a>

    <a class="nav-btn nav-shopall" href="/shop_all.html">
      <img src="/static/img/buttons/shop-all.png" alt="Shop All">
    </a>

    <a class="nav-btn nav-cart" href="/cart/">
      <img src="/static/img/buttons/cart.png" alt="Cart">
    </a>

    <!-- 💤 HIDDEN FOR LATER (DO NOT DELETE) -->
    <a class="nav-btn nav-hidden" href="/necklaces/">
      <img src="/static/img/buttons/necklaces.png" alt="Necklaces">
    </a>

    <a class="nav-btn nav-hidden" href="/bronze/">
      <img src="/static/img/buttons/bronze.png" alt="Bronze">
    </a>

    <a class="nav-btn nav-hidden" href="/earrings/">
      <img src="/static/img/buttons/earrings.png" alt="Earrings">
    </a>

    <a class="nav-btn nav-hidden" href="/pendants/">
      <img src="/static/img/buttons/pendants.png" alt="Pendants">
    </a>

    <a class="nav-btn nav-hidden" href="/customize.html">
      <img src="/static/img/buttons/customize.png" alt="Customize">
    </a>

  </div>
</header>

<main>
  {% block content %}
    {{ content | safe }}
  {% endblock %}
</main>

{% block footer %}
<footer class="site-footer">
  <div class="footer-brand">
    <span class="footer-text">Custom Design’s</span>
    <img
      src="/assets/uploads/logo.png"
      alt="Custom Design’s LA Logo"
      class="footer-logo"
    />
  </div>

  <p class="footer-copy">
    © <script>document.write(new Date().getFullYear())</script>
    Custom Design’s LA — All Rights Reserved.
  </p>
</footer>
{% endblock %}

<script src="/static/js/mobile-gesture-lock.js" defer></script>
<script src="/static/js/home-slider.js" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggle = document.querySelector('.collections-toggle');
    const bar = document.getElementById('collections-bar');
    if (!toggle || !bar) return;

    toggle.setAttribute('aria-expanded', 'false');

    toggle.addEventListener('click', function (event) {
      event.preventDefault();
      const isOpen = bar.classList.toggle('is-open');
      document.querySelector('.site-header')?.classList.toggle('collections-open', isOpen);
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  });
</script>

</body>
</html>
