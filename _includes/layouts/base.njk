<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{{ title | default("Custom Design's LA") }}</title>

  <link rel="stylesheet" href="/static/css/styles.css">
  <link rel="stylesheet" href="/static/css/ltr.css">

  <!-- Collections Toggle Styles + Sticky Header -->
  <style>
    .collections-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 260px;
      max-width: 260px;
      height: 58px;
      margin: 0.65rem 0 0.45rem 24px;
      padding: 4px 12px;
      border-radius: 999px;
      border: 2px solid rgba(210, 210, 210, 0.95);
      background: linear-gradient(180deg, rgba(250,250,250,0.92), rgba(210,210,210,0.88));
      color: #111;
      cursor: pointer;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.8),
        inset 0 -1px 0 rgba(0,0,0,0.18),
        0 4px 10px rgba(0,0,0,0.12);
    }

    .collections-toggle:hover {
      background: linear-gradient(to bottom, #ffffff, #e3e3e3);
    }

    .header-logo-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 100%;
    }

    .cdla-header-wordmark {
      display: block;
      width: clamp(260px, 58vw, 420px);
      height: auto;
      object-fit: contain;
    }

    .cdla-collections-button-img {
      display: block;
      width: 92%;
      max-width: 230px;
      height: auto;
      object-fit: contain;
    }

    .brand-logo {
      width: clamp(48px, 11vw, 72px);
      height: auto;
      flex-shrink: 0;
    }

    .top-button-bar {
      display: none;
    }

    .top-button-bar.is-open {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: nowrap; /* Desktop: single row */
      padding: 0.45rem 0.7rem;
    }

    /* Button images: base size */
    .top-button-bar a img {
      height: 38px;
      width: auto;
      display: block;
    }

    /* Hide future buttons (keep in code) */
    .nav-hidden {
      display: none !important;
    }

    /* Mobile: 3 on top, 2 centered */
    @media (max-width: 768px) {
      .top-button-bar.is-open {
        flex-wrap: wrap;
        max-width: 360px;
        margin: 0 auto;
        justify-content: center;
      }

      .top-button-bar a img {
        height: 36px;
      }
    }

    /* Desktop: make nav buttons bigger */
    @media (min-width: 769px) {
      .top-button-bar.is-open {
        padding-top: 0.35rem;
        padding-bottom: 0.6rem;
        gap: 0.9rem;
      }

      .top-button-bar a img {
        height: 44px;
      }

      /* Slightly tighten spacing under the Collections toggle */
      .collections-toggle {
        margin-bottom: 0.25rem;
      }
    }


    @media (max-width: 640px) {
      .cdla-header-wordmark {
        width: clamp(245px, 62vw, 350px);
      }

      .brand-logo {
        width: clamp(48px, 12vw, 64px);
      }

      .collections-toggle {
        width: 250px;
        max-width: 250px;
        height: 56px;
        margin-left: 24px;
      }

      .cdla-collections-button-img {
        width: 94%;
        max-width: 225px;
      }
    }

    .site-header,
    header {
      position: sticky;
      top: 0;
      z-index: 1500;
      background: linear-gradient(
        to bottom,
        #f2f2f2 0%,
        #e4e4e4 45%,
        #d6d6d6 100%
      );
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }

    main {
      padding-top: 1.5rem;
    }

    @media (max-width: 768px) {
      main {
        padding-top: 1.5rem;
      }
    }
  </style>
</head>

<body>

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand header-logo-row">
      <img src="/static/img/cdla-header-wordmark.png" alt="Custom Design’s LA" class="cdla-header-wordmark">
      <img
        src="/assets/uploads/logo.png"
        alt="Custom Design's LA Logo"
        class="brand-logo"
      />
    </a>
  </div>

  <button
    class="collections-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="collections-bar"
  >
    <img src="/static/img/cdla-explore-collections-button.png" alt="Explore CDLA Collections" class="cdla-collections-button-img">
  </button>

  <div class="top-button-bar" id="collections-bar">

    <!-- ✅ LIVE BUTTONS (ONLY 5) -->
    <a class="nav-btn nav-rings" href="/rings/">
      <img src="/static/img/buttons/rings.png" alt="Rings">
    </a>

    <a class="nav-btn nav-charms" href="/charms/">
      <img src="/static/img/buttons/charms.png" alt="Charms">
    </a>

    <a class="nav-btn nav-bracelets" href="/bracelets/">
      <img src="/static/img/buttons/bracelets.png" alt="Bracelets">
    </a>

    <a class="nav-btn nav-shopall" href="/shop_all.html">
      <img src="/static/img/buttons/shop-all.png" alt="Shop All">
    </a>

    <a class="nav-btn nav-cart" href="/cart/">
      <img src="/static/img/buttons/cart.png" alt="Cart">
    </a>

    <!-- 💤 HIDDEN FOR LATER (DO NOT DELETE) -->
    <a class="nav-btn nav-hidden" href="/necklaces/">
      <img src="/static/img/buttons/necklaces.png" alt="Necklaces">
    </a>

    <a class="nav-btn nav-hidden" href="/bronze/">
      <img src="/static/img/buttons/bronze.png" alt="Bronze">
    </a>

    <a class="nav-btn nav-hidden" href="/earrings/">
      <img src="/static/img/buttons/earrings.png" alt="Earrings">
    </a>

    <a class="nav-btn nav-hidden" href="/pendants/">
      <img src="/static/img/buttons/pendants.png" alt="Pendants">
    </a>

    <a class="nav-btn nav-hidden" href="/customize.html">
      <img src="/static/img/buttons/customize.png" alt="Customize">
    </a>

  </div>
</header>

<main>
  {% block content %}
    {{ content | safe }}
  {% endblock %}
</main>

{% block footer %}
<footer class="site-footer">
  <div class="footer-brand">
    <span class="footer-text">Custom Design’s</span>
    <img
      src="/assets/uploads/logo.png"
      alt="Custom Design’s LA Logo"
      class="footer-logo"
    />
  </div>

  <p class="footer-copy">
    © <script>document.write(new Date().getFullYear())</script>
    Custom Design’s LA — All Rights Reserved.
  </p>
</footer>
{% endblock %}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.querySelector(".collections-toggle");
    const bar = document.querySelector(".top-button-bar");
    if (!toggle || !bar) return;
    toggle.addEventListener("click", () => {
      const isOpen = bar.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", isOpen);
    });
  });
</script>


<script src="/static/js/mobile-gesture-lock.js" defer></script>
<script src="/static/js/home-slider.js" defer></script>

</body>
</html>
