{% extends "layouts/base.njk" %}

{% block content %}
<section class="product-page product-page-minimal">
  <div class="container">

    {# ===============================
       PRODUCT GALLERY (AUTHORITATIVE)
       =============================== #}
    {% set productGallery = gallery or page.data.gallery %}
    {% if productGallery and productGallery.length %}
      <section class="product-gallery-section">
        <div class="product-gallery-grid">
          {% for image in productGallery %}
            <div class="product-gallery-item">
              <img
                src="{{ image }}"
                alt="{{ title or page.data.title }} image {{ loop.index }}"
                loading="lazy"
              >
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="product-summary">
      <h1 class="product-title">{{ title or page.data.title }}</h1>

      <h2 class="product-section-heading">Overview</h2>
      {% set overviewHtml = "" %}
      {% if "<h2>Overview</h2>" in content %}
        {% set overviewParts = content.split("<h2>Overview</h2>") %}
        {% if overviewParts.length > 1 %}
          {% set overviewHtml = overviewParts[1] %}
          {% for headingStop in [
            "<p><strong>Total:",
            "<p><strong>Total:</strong>",
            "<p><strong>➡️ Total:",
            "<p><strong>➡️ Total:</strong>",
            "<h2>Breakdown</h2>",
            "<h2>Specifications</h2>",
            "<h2>Notes</h2>",
            "<h3>Breakdown</h3>",
            "<h3>Specifications</h3>",
            "<h3>Notes</h3>",
            "<h2>"
          ] %}
            {% if headingStop in overviewHtml %}
              {% set overviewHtml = overviewHtml.split(headingStop)[0] %}
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}

      <div class="product-overview-copy">
        {% if overviewHtml | trim %}
          {{ overviewHtml | safe }}
        {% elif description or page.data.description %}
          <p>{{ description or page.data.description }}</p>
        {% endif %}
      </div>

      {% if price or page.data.price %}
        <p class="product-total">Total: ${{ price or page.data.price }} USD</p>
      {% endif %}

      <!-- ✅ Customize CTA button (routes to builder) -->
      {% set productSku = sku or page.fileSlug %}
      {% set urlPath = page.url or "" %}
      {# Detect builder type by URL path (Nunjucks-safe) #}
      {% set isRing = "/rings/" in urlPath %}
      {% set isRingBuilderEligible = ("/rings/cuban-link/" in urlPath) or ("/rings/western/" in urlPath) or ("/rings/faith/" in urlPath) %}

      {% if isRingBuilderEligible or not isRing %}
        {% if isRing %}
          {% set builderPath = "/builder/ring/" %}
        {% else %}
          {% set builderPath = "/builder/charm/" %}
        {% endif %}

        <div class="product-add-to-cart-wrap product-customize-wrap">
          <a
            href="{{ builderPath }}?sku={{ productSku | urlencode }}"
            class="product-add-to-cart-link product-customize-link"
            aria-label="Customize and checkout"
          >
            <img
              src="/static/img/ui/add-to-cart.png"
              alt="Customize"
              class="product-add-to-cart-btn product-customize-btn"
              loading="lazy"
            >
          </a>
        </div>
      {% endif %}
    </section>

  </div>
</section>
{% endblock %}
